{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/public/assets/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/index.html",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/public/index.html",
      "permanent": false
    }
  ]
}
